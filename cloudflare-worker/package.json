{
    "name": "r2-upload-worker",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "wrangler dev",
        "deploy": "wrangler deploy",
        "seo:dev": "wrangler dev --config wrangler.seo.toml",
        "seo:deploy": "wrangler deploy --config wrangler.seo.toml",
        "seo:secret:url": "wrangler secret put SUPABASE_URL --config wrangler.seo.toml",
        "seo:secret:key": "wrangler secret put SUPABASE_ANON_KEY --config wrangler.seo.toml"
    },
    "devDependencies": {
        "@cloudflare/workers-types": "^4.20241205.0",
        "typescript": "^5.3.0",
        "wrangler": "^3.99.0"
    }
}