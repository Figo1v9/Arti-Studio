// Service Worker for Prompt Life
// Handles caching with proper request method filtering

const CACHE_NAME = 'prompt-life-v1';

// Only cache GET requests - POST, HEAD, etc are not supported
const isValidRequestMethod = (request) => {
    return request.method === 'GET';
};

// Install event
self.addEventListener('install', (event) => {
    self.skipWaiting();
});

// Activate event
self.addEventListener('activate', (event) => {
    event.waitUntil(
        caches.keys().then((cacheNames) => {
            return Promise.all(
                cacheNames.map((cacheName) => {
                    if (cacheName !== CACHE_NAME) {
                        return caches.delete(cacheName);
                    }
                })
            );
        })
    );
    self.clients.claim();
});

// Fetch event - only cache GET requests
self.addEventListener('fetch', (event) => {
    // Skip non-GET requests (POST, HEAD, etc. cannot be cached)
    if (!isValidRequestMethod(event.request)) {
        return;
    }

    // Skip chrome-extension and other non-http requests
    if (!event.request.url.startsWith('http')) {
        return;
    }

    // Skip API calls and authentication endpoints
    if (
        event.request.url.includes('/rest/v1/') ||
        event.request.url.includes('supabase.co') ||
        event.request.url.includes('firebaseapp.com') ||
        event.request.url.includes('googleapis.com') ||
        event.request.url.includes('identitytoolkit')
    ) {
        return;
    }

    event.respondWith(
        caches.match(event.request).then((cachedResponse) => {
            if (cachedResponse) {
                return cachedResponse;
            }

            return fetch(event.request).then((response) => {
                // Don't cache non-successful responses
                if (!response || response.status !== 200 || response.type !== 'basic') {
                    return response;
                }

                // Clone the response
                const responseToCache = response.clone();

                caches.open(CACHE_NAME).then((cache) => {
                    // Double-check it's a GET request before caching
                    if (isValidRequestMethod(event.request)) {
                        cache.put(event.request, responseToCache);
                    }
                });

                return response;
            });
        }).catch(() => {
            // Return a fallback for navigation requests
            if (event.request.mode === 'navigate') {
                return caches.match('/index.html');
            }
        })
    );
});
