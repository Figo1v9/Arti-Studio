{
    "cleanUrls": false,
    "trailingSlash": false,
    "routes": [
        {
            "src": "/sitemap.xml",
            "dest": "/sitemap.xml",
            "headers": {
                "Cache-Control": "public, max-age=3600, must-revalidate",
                "Content-Type": "application/xml; charset=utf-8"
            }
        },
        {
            "src": "/robots.txt",
            "dest": "/robots.txt",
            "headers": {
                "Cache-Control": "public, max-age=3600, must-revalidate",
                "Content-Type": "text/plain; charset=utf-8"
            }
        },
        {
            "src": "/ads.txt",
            "dest": "/ads.txt",
            "headers": {
                "Cache-Control": "public, max-age=86400, must-revalidate"
            }
        },
        {
            "src": "/manifest.json",
            "dest": "/manifest.json",
            "headers": {
                "Cache-Control": "public, max-age=86400, must-revalidate"
            }
        },
        {
            "src": "/manifest.webmanifest",
            "dest": "/manifest.webmanifest",
            "headers": {
                "Cache-Control": "public, max-age=86400, must-revalidate"
            }
        },
        {
            "src": "/favicon.ico",
            "dest": "/favicon.ico"
        },
        {
            "src": "/sw.js",
            "dest": "/sw.js",
            "headers": {
                "Cache-Control": "public, max-age=0, must-revalidate"
            }
        },
        {
            "src": "/assets/(.*)",
            "dest": "/assets/$1",
            "headers": {
                "Cache-Control": "public, max-age=31536000, immutable"
            }
        },
        {
            "src": "/registerSW.js",
            "dest": "/registerSW.js"
        },
        {
            "src": "/workbox-(.+)\\.js",
            "dest": "/workbox-$1.js"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html",
            "headers": {
                "Cache-Control": "no-cache, no-store, must-revalidate"
            }
        }
    ]
}